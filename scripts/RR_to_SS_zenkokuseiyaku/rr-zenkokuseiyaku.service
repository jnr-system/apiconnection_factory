[Unit]
Description=RR to SS 全国成約同期
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/project/apiconnection_factory/scripts/RR_to_SS_zenkokuseiyaku
EnvironmentFile=/etc/apiconnection.env
ExecStart=/root/project/apiconnection_factory/venv/bin/python RR_to_SS_zenkokuseiyaku.py
StandardOutput=journal
StandardError=journal
