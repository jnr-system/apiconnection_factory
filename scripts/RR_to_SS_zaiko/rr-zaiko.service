[Unit]
Description=RR to SS 在庫同期
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/root/project/apiconnection_factory/scripts/RR_to_SS_zaiko
EnvironmentFile=/etc/apiconnection.env
ExecStart=/root/project/apiconnection_factory/venv/bin/python RR_to_SS_zaiko.py
StandardOutput=journal
StandardError=journal
